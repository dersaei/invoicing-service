# ─────────────────────────────────────────────────────────────
#  invoicing-service — environment variables
#  Copy to .env and fill in. In production, Doppler injects these.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Webhook security (HMAC) ──────────────────────────────────
# Generate with: openssl rand -hex 32
# The same secret must be used in the Directus Flow "Run Script" step.
WEBHOOK_SECRET=

# ── Invoicing database (Postgres, separate from Directus) ────
INVOICING_DB_HOST=invoicing-db
INVOICING_DB_PORT=5432
INVOICING_DB_NAME=invoicing
INVOICING_DB_USER=invoicing_app
INVOICING_DB_PASSWORD=

# ── Directus ─────────────────────────────────────────────────
# Internal URL on the Docker network (not the public one).
DIRECTUS_URL=http://directus:8055
# Static admin token: Directus → Settings → Users → (user) → Token
DIRECTUS_TOKEN=

# ── Fastmail SMTP ────────────────────────────────────────────
FASTMAIL_SMTP_HOST=smtp.fastmail.com
FASTMAIL_SMTP_PORT=465
FASTMAIL_SMTP_USER=
# App-specific password (NOT your main Fastmail login)
FASTMAIL_APP_PASSWORD=
# From / reply-to shown on outgoing invoice emails
MAIL_FROM="Spiżarnia Regio <faktury@spizarniaregio.example>"

# ── VIES (EU VAT validation) ─────────────────────────────────
# Public SOAP endpoint; override only if using a proxy.
VIES_ENDPOINT=https://ec.europa.eu/taxation_customs/vies/services/checkVatService
# Milliseconds before a VIES call is considered timed out.
VIES_TIMEOUT_MS=8000
