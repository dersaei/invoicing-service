# ── Secrets (managed by Doppler; never commit) ───────────────
.env
.env.*
!.env.example

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build output ─────────────────────────────────────────────
dist/
*.tsbuildinfo

